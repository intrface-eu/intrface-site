{
  "name": "@intrface/workspace",
  "private": true,
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && bun run dev",
    "dev:aoc": "cd apps/aoc && bun run dev",
    "build": "cd apps/web && bun run build && cd ../../apps/aoc && bun run build",
    "build:web": "cd apps/web && bun run build",
    "build:aoc": "cd apps/aoc && bun run build",
    "lint": "cd apps/web && bun run lint && cd ../../apps/aoc && bun run lint",
    "lint:web": "cd apps/web && bun run lint",
    "lint:aoc": "cd apps/aoc && bun run lint"
  }
}
